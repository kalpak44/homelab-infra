# Homelab Ansible
#
# Usage:
#   just bootstrap <ip>                # one-time Proxmox setup (see bootstrap/README.md)
#   just configure <resource>          # per-service config, e.g. just configure adguard-lxc
#   just configure k3s-cluster/flux    # runs the flux-install.yml variant
#   just list                          # show all configurable resources
#
# Env vars (workflow injects them; locally come from your shell):
#   CLOUDFLARE_API_TOKEN, LETSENCRYPT_EMAIL, PROXMOX_DOMAIN   (bootstrap)
#   GITHUB_TOKEN (PAT with repo scope), GITHUB_REPO (owner/repo)    (bootstrap - runner auto-register)
#   ADGUARD_USERNAME/PASSWORD, VAULT_USERNAME/PASSWORD,
#   POSTGRESQL_USER/PASSWORD/DB, PGADMIN_EMAIL/PASSWORD,
#   REDIS_PASSWORD, REDIS_COMMANDER_USER/PASSWORD,
#   RABBITMQ_USER/PASSWORD,
#   FLUX_GITHUB_TOKEN
#   HOST_PASSWORD (root password for all LXCs/VMs - used for SSH + sudo)

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

_help:
    @just --list

# Install passlib + sshpass. Idempotent.
[private]
setup:
    #!/usr/bin/env bash
    set -euo pipefail
    missing=()
    python3 -c 'import passlib' 2>/dev/null || missing+=(python3-passlib)
    command -v sshpass >/dev/null 2>&1 || missing+=(sshpass)
    if [[ ${#missing[@]} -gt 0 ]]; then
      if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get update -qq
        sudo apt-get install -y "${missing[@]}"
      elif command -v brew >/dev/null 2>&1; then
        brew install hudochenkov/sshpass/sshpass python-passlib 2>/dev/null || true
      else
        echo "install manually: ${missing[*]}" >&2
        exit 1
      fi
    fi

# Run the playbook for a service (or k3s-cluster/flux)
configure resource: setup
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{resource}}" in
      k3s-cluster)      playbook="proxmox/k3s-cluster/cluster-setup.yml" ;;
      k3s-cluster/flux) playbook="proxmox/k3s-cluster/flux-install.yml" ;;
      *)                playbook="proxmox/{{resource}}/playbook.yml" ;;
    esac
    ansible-playbook "$playbook" \
      -e "host_password=${HOST_PASSWORD:-}" \
      -e "cloudflare_api_token=${CLOUDFLARE_API_TOKEN:-}" \
      -e "letsencrypt_email=${LETSENCRYPT_EMAIL:-}" \
      -e "adguard_username=${ADGUARD_USERNAME:-}" \
      -e "adguard_password=${ADGUARD_PASSWORD:-}" \
      -e "vault_username=${VAULT_USERNAME:-}" \
      -e "vault_password=${VAULT_PASSWORD:-}" \
      -e "postgresql_user=${POSTGRESQL_USER:-}" \
      -e "postgresql_password=${POSTGRESQL_PASSWORD:-}" \
      -e "postgresql_db=${POSTGRESQL_DB:-}" \
      -e "pgadmin_email=${PGADMIN_EMAIL:-}" \
      -e "pgadmin_password=${PGADMIN_PASSWORD:-}" \
      -e "redis_password=${REDIS_PASSWORD:-}" \
      -e "redis_commander_user=${REDIS_COMMANDER_USER:-}" \
      -e "redis_commander_password=${REDIS_COMMANDER_PASSWORD:-}" \
      -e "rabbitmq_user=${RABBITMQ_USER:-}" \
      -e "rabbitmq_password=${RABBITMQ_PASSWORD:-}" \
      -e "flux_github_token=${FLUX_GITHUB_TOKEN:-}" \
      -e "cloudflare_tunnel_token=${CLOUDFLARE_TUNNEL_TOKEN:-}"

# Bootstrap a fresh Proxmox node (SSH key auth) - see bootstrap/README.md
bootstrap ip user='root': setup
    ansible-playbook -i "{{ip}}," -u {{user}} \
      -e "host_password=${HOST_PASSWORD:-}" \
      -e "letsencrypt_email=${LETSENCRYPT_EMAIL:-}" \
      -e "cloudflare_api_token=${CLOUDFLARE_API_TOKEN:-}" \
      -e "proxmox_domain=${PROXMOX_DOMAIN:-proxmox.internal.pavel-usanli.online}" \
      -e "github_token=${GITHUB_TOKEN:-}" \
      -e "github_repo=${GITHUB_REPO:-}" \
      bootstrap/main.yml

# Bootstrap a fresh Proxmox node (SSH password prompt - fresh node with no keys)
bootstrap-pw ip user='root': setup
    ansible-playbook -i "{{ip}}," -u {{user}} --ask-pass \
      -e "host_password=${HOST_PASSWORD:-}" \
      -e "letsencrypt_email=${LETSENCRYPT_EMAIL:-}" \
      -e "cloudflare_api_token=${CLOUDFLARE_API_TOKEN:-}" \
      -e "proxmox_domain=${PROXMOX_DOMAIN:-proxmox.internal.pavel-usanli.online}" \
      -e "github_token=${GITHUB_TOKEN:-}" \
      -e "github_repo=${GITHUB_REPO:-}" \
      bootstrap/main.yml

# List every configurable resource
list:
    @echo "Bootstrap (one-time, fresh Proxmox node):"
    @printf "  %-24s %s\n" "bootstrap <ip>"    "Full bootstrap - Terraform user, base artifacts, runner VM, TLS cert"
    @printf "  %-24s %s\n" "bootstrap-pw <ip>" "Same, but prompts for SSH password (no key access yet)"
    @echo
    @echo "Configure (per-service, run after Terraform provisions the host):"
    @printf "  %-24s %s\n" "adguard-lxc"      "AdGuard Home - network-wide DNS ad-blocker"
    @printf "  %-24s %s\n" "vault-lxc"        "HashiCorp Vault - secrets manager"
    @printf "  %-24s %s\n" "postgres-lxc"     "PostgreSQL + pgAdmin - database and web UI"
    @printf "  %-24s %s\n" "redis-lxc"        "Redis + Redis Commander - cache and web UI"
    @printf "  %-24s %s\n" "rabbitmq-lxc"     "RabbitMQ - message broker"
    @printf "  %-24s %s\n" "nfs-vm"           "NFS server - persistent volumes for k3s"
    @printf "  %-24s %s\n" "portainer-vm"     "Portainer - Docker container management UI"
    @printf "  %-24s %s\n" "cloudflared-lxc"  "Cloudflare Tunnel daemon - WAN-less public ingress"
    @printf "  %-24s %s\n" "k3s-cluster"      "k3s cluster - 2-node control-plane + worker"
    @printf "  %-24s %s\n" "k3s-cluster/flux" "Flux CD - GitOps bootstrap on the k3s cluster"