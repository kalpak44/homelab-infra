# Homelab Terraform
#
# Usage:
#   just deploy  <layer> <resource>   # e.g. just deploy cloudflare dns/private/adguard
#   just destroy <layer> <resource>   # e.g. just destroy proxmox adguard-lxc
#
# Layers: cloudflare | proxmox
# Resource: subdir under the layer (see `just list`)
#
# Env vars (must be set - the workflow injects them, locally they come from your shell).
# Names match the GitHub secrets 1:1; this Justfile maps them to what terraform + the
# AWS-compatible S3 SDK expect (AWS_*, TF_VAR_*) right before terraform runs.
#
#   R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_ENDPOINT, R2_BUCKET_NAME     (both layers)
#   CLOUDFLARE_API_TOKEN                                                     (cloudflare layer)
#   PROXMOX_ENDPOINT, PROXMOX_USERNAME, PROXMOX_PASSWORD,
#   SSH_PUBLIC_KEY, SSH_PRIVATE_KEY, HOST_PASSWORD                          (proxmox layer)

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

_help:
    @just --list

# Terraform init + apply
deploy layer resource:
    #!/usr/bin/env bash
    set -euo pipefail
    export AWS_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID:-}"
    export AWS_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY:-}"
    export AWS_ENDPOINT_URL_S3="${R2_ENDPOINT:-}"
    export TF_VAR_cloudflare_api_token="${CLOUDFLARE_API_TOKEN:-}"

    export TF_VAR_proxmox_endpoint="${PROXMOX_ENDPOINT:-}"
    export TF_VAR_proxmox_username="${PROXMOX_USERNAME:-}"
    export TF_VAR_proxmox_password="${PROXMOX_PASSWORD:-}"
    export TF_VAR_ssh_public_key="${SSH_PUBLIC_KEY:-}"
    export TF_VAR_ssh_private_key="${SSH_PRIVATE_KEY:-}"
    export TF_VAR_host_password="${HOST_PASSWORD:-ubuntu}"
    cd {{layer}}/{{resource}}
    terraform init -backend-config="bucket=$R2_BUCKET_NAME" -input=false
    terraform apply -auto-approve -input=false

# Terraform init + destroy
destroy layer resource:
    #!/usr/bin/env bash
    set -euo pipefail
    export AWS_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID:-}"
    export AWS_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY:-}"
    export AWS_ENDPOINT_URL_S3="${R2_ENDPOINT:-}"
    export TF_VAR_cloudflare_api_token="${CLOUDFLARE_API_TOKEN:-}"

    export TF_VAR_proxmox_endpoint="${PROXMOX_ENDPOINT:-}"
    export TF_VAR_proxmox_username="${PROXMOX_USERNAME:-}"
    export TF_VAR_proxmox_password="${PROXMOX_PASSWORD:-}"
    export TF_VAR_ssh_public_key="${SSH_PUBLIC_KEY:-}"
    export TF_VAR_ssh_private_key="${SSH_PRIVATE_KEY:-}"
    export TF_VAR_host_password="${HOST_PASSWORD:-ubuntu}"
    cd {{layer}}/{{resource}}
    terraform init -backend-config="bucket=$R2_BUCKET_NAME" -input=false
    terraform destroy -auto-approve -input=false

# Print a sensitive terraform output (e.g. just output cloudflare shared/zero-trust tunnel_token)
output layer resource name:
    #!/usr/bin/env bash
    set -euo pipefail
    export AWS_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID:-}"
    export AWS_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY:-}"
    export AWS_ENDPOINT_URL_S3="${R2_ENDPOINT:-}"
    cd {{layer}}/{{resource}}
    terraform init -backend-config="bucket=$R2_BUCKET_NAME" -input=false -reconfigure 2>/dev/null
    terraform output -raw {{name}}

