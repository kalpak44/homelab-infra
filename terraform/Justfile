# Homelab Terraform
#
# Usage:
#   just deploy  <layer> <resource>   # e.g. just deploy cloudflare dns/private/adguard
#   just destroy <layer> <resource>   # e.g. just destroy proxmox adguard-lxc
#
# Layers: cloudflare | proxmox
# Resource: subdir under the layer (see `just list`)
#
# Env vars (must be set - the workflow injects them, locally they come from your shell):
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_ENDPOINT_URL_S3, R2_BUCKET_NAME
#   TF_VAR_cloudflare_api_token, TF_VAR_haproxy_public_ip     (cloudflare layer)
#   TF_VAR_proxmox_endpoint, TF_VAR_proxmox_username,
#   TF_VAR_proxmox_password, TF_VAR_ssh_public_key,
#   TF_VAR_ssh_private_key                                    (proxmox layer)

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

_help:
    @just --list

# Terraform init + apply
deploy layer resource:
    cd {{layer}}/{{resource}} && \
      terraform init -backend-config="bucket=$R2_BUCKET_NAME" -input=false && \
      terraform apply -auto-approve -input=false

# Terraform init + destroy
destroy layer resource:
    cd {{layer}}/{{resource}} && \
      terraform init -backend-config="bucket=$R2_BUCKET_NAME" -input=false && \
      terraform destroy -auto-approve -input=false

